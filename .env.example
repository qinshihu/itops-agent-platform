# ==============================================================================
# ITOps Agent Platform - 环境变量配置示例
# ==============================================================================
# 📝 说明：
#   - 复制此文件为 .env 并根据实际情况修改
#   - 所有配置项均为可选，有默认值
#   - AI 模型配置也可在登录后在网页 "设置 → AI 配置" 中设置

# ==============================================================================
# 🔧 基础配置
# ==============================================================================

# 运行环境 (development/production)
# 默认: production
NODE_ENV=development

# 后端服务端口
# 默认: 3001
PORT=3001

# SQLite 数据库文件路径
# 默认: ./data/app.db
DATABASE_PATH=./data/app.db

# ==============================================================================
# 🔐 JWT 认证配置
# ==============================================================================

# JWT 签名密钥（生产环境必须修改！）
# 🚨 安全警告：生产环境必须使用强随机密钥
# 生成命令: openssl rand -hex 32
# 开发环境不设置会自动生成，生产环境必须设置
JWT_SECRET=your-production-secret-key-change-me-32-chars

# Access Token 有效期
# 格式示例: 24h, 7d, 60m
# 默认: 24h
JWT_EXPIRES_IN=24h

# ==============================================================================
# 👤 管理员初始密码（首次部署生效）
# ==============================================================================

# 管理员初始密码（首次部署数据库为空时生效）
# 不设置默认为: admin
# 🚨 安全警告：首次登录后系统会强制要求修改此密码
# ADMIN_INITIAL_PASSWORD=your-initial-admin-password

# ==============================================================================
# 🌐 CORS 跨域配置
# ==============================================================================

# 允许的跨域来源（逗号分隔多个地址）
# 建议仅允许实际访问的域名，增强安全性
# 默认: http://localhost,http://localhost:3000,http://localhost:8080
ALLOWED_ORIGINS=http://localhost,http://localhost:3000,http://localhost:8080

# ==============================================================================
# 🤖 AI 模型配置（豆包 / 火山引擎）
# ==============================================================================
# 注意：这些配置也可以在登录后在网页 "设置 → AI 配置" 中设置

# 豆包 API 密钥
# 申请地址: https://console.volcengine.com/ark
DOUBAO_API_KEY=

# 豆包 API 地址
# 默认: https://ark.cn-beijing.volces.com/api/v3
DOUBAO_API_BASE=https://ark.cn-beijing.volces.com/api/v3

# 豆包模型名称
# 示例: doubao-4o, doubao-pro-32k, doubao-lite-32k
# 默认: doubao-4o
DOUBAO_MODEL=doubao-4o

# ==============================================================================
# 🤖 AI 模型配置（OpenAI / 兼容 OpenAI 接口）
# ==============================================================================

# OpenAI API 密钥
OPENAI_API_KEY=

# OpenAI API 地址
# 默认: https://api.openai.com/v1
OPENAI_API_BASE=https://api.openai.com/v1

# OpenAI 模型名称
# 示例: gpt-4o, gpt-4-turbo, gpt-3.5-turbo
# 默认: gpt-4o
OPENAI_MODEL=gpt-4o

# ==============================================================================
# 🏠 本地 AI 模型配置（Ollama / LM Studio / vLLM 等）
# ==============================================================================

# 本地 AI API 地址
# Ollama 示例: http://localhost:11434/v1
# LM Studio 示例: http://localhost:1234/v1
LOCAL_AI_API_BASE=

# 本地 AI 模型名称
# 示例: qwen2.5, llama3, deepseek-coder, yi
LOCAL_AI_MODEL=

# ==============================================================================
# 🚨 Webhook 安全配置（告警接收）
# ==============================================================================
# 📝 生产环境强烈建议配置，防止伪造告警攻击

# 是否启用 Webhook 签名验证
# 启用后，告警源必须在请求头中携带正确的 HMAC-SHA256 签名
# 签名 Header 格式: X-Webhook-Signature-{source} (如 X-Webhook-Signature-prometheus)
# 默认: false
WEBHOOK_VERIFY_ENABLED=false

# Webhook 签名密钥
# 🚨 启用签名验证时必须设置
# 生成命令: openssl rand -hex 32
WEBHOOK_SECRET=your-webhook-secret-key-change-me

# Webhook IP 白名单（逗号分隔多个 IP）
# 只允许白名单中的 IP 发送告警请求
# 空值表示允许所有 IP（不推荐用于生产）
# 示例: WEBHOOK_IP_WHITELIST=192.168.1.100,10.0.0.50
WEBHOOK_IP_WHITELIST=

# ==============================================================================
# 📝 日志配置
# ==============================================================================

# 日志级别: debug, info, warn, error
# 默认: info
LOG_LEVEL=info

# ==============================================================================
# 📚 配置优先级说明
# ==============================================================================
#
# 1. 环境变量（.env 文件）优先级最高
# 2. 网页配置（存储在数据库中）在环境变量未设置时生效
# 3. 均未配置时使用代码内的默认值
#
# 🔐 安全最佳实践：
#   - 生产环境必须设置 JWT_SECRET
#   - 生产环境建议启用 WEBHOOK_VERIFY_ENABLED 和 WEBHOOK_IP_WHITELIST
#   - 不要将包含真实密钥的 .env 文件提交到代码仓库
#   - 定期轮换所有密钥
#
# 🚀 部署后访问：
#   - 前端: http://localhost:8080
#   - 后端: http://localhost:3001
#   - 健康检查: http://localhost:3001/health
#
# ==============================================================================
