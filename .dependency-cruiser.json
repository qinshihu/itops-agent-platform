{

  "options": {
    "doNotFollow": {
      "path": "node_modules"
    },
    "reporterOptions": {
      "dot": {
        "collapsePattern": "node_modules/[^/]+"
      },
      "archi": {
        "collapsePattern": "node_modules/[^/]+"
      }
    }
  },

  "forbidden": [
    {
      "name": "core-禁止依赖-modules",
      "severity": "error",
      "comment": "core/ 是基础设施层，不得依赖任何业务模块（参照 ongrid: shared_pkg mayDependOn: []）",
      "from": {
        "path": "^src/core/"
      },
      "to": {
        "path": "^src/modules/"
      }
    },
    {
      "name": "repositories-禁止依赖-modules",
      "severity": "error",
      "comment": "repositories/ 层是纯数据访问层，不能反向依赖 modules/ 业务层",
      "from": {
        "path": "^src/repositories"
      },
      "to": {
        "path": "^src/modules"
      }
    },
    {
      "name": "modules-禁止跨模块路由依赖",
      "severity": "error",
      "comment": "modules/ 之间禁止直接 import 对方的 routes.ts（防止路由层耦合）",
      "from": {
        "path": "^src/modules/([^/]+)/routes\\.ts$"
      },
      "to": {
        "path": "^src/modules/",
        "pathNot": "^src/modules/$1/"
      }
    },
    {
      "name": "modules-禁止循环依赖-core",
      "severity": "error",
      "comment": "core/ 中的模块之间也不应有循环依赖",
      "from": {
        "path": "^src/core/"
      },
      "to": {
        "path": "^src/core/",
        "circular": true
      }
    },
    {
      "name": "modules-禁止循环依赖",
      "severity": "error",
      "comment": "业务模块之间禁止循环依赖",
      "from": {
        "path": "^src/modules/"
      },
      "to": {
        "path": "^src/modules/",
        "circular": true
      }
    },
    {
      "name": "frontend-禁止跨模块直接引用页面",
      "severity": "error",
      "comment": "前端模块之间禁止直接 import 对方的页面组件（使用 shared/components/ 共享组件）",
      "from": {
        "path": "^frontend/src/modules/([^/]+)/"
      },
      "to": {
        "path": "^frontend/src/modules/",
        "pathNot": "^frontend/src/modules/$1/"
      }
    }
  ],

  "allowedSeverity": "warn",
  "allowed": [
    {
      "from": { "path": "^src/core/" },
      "to": { "path": "^src/core/" }
    },
    {
      "from": { "path": "^src/modules/" },
      "to": { "path": "^src/core/" }
    },
    {
      "from": { "path": "^src/app\\.ts$" },
      "to": { "path": "^src/" }
    },
    {
      "from": { "path": "^frontend/src/modules/" },
      "to": { "path": "^frontend/src/shared/" }
    },
    {
      "from": { "path": "^src/modules/([^/]+)/services/" },
      "to": { "path": "^src/modules/([^/]+)/services/" }
    }
  ]
}
