# =============================================================================
# 一、依赖（Dependencies）
# =============================================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*


# =============================================================================
# 二、构建产物（Build outputs）
# -----------------------------------------------------------------------------
# TypeScript 编译到 dist/，其他工具链用 build/，双覆盖以防遗漏
# =============================================================================
backend/dist/
backend/build/
frontend/dist/
frontend/build/


# =============================================================================
# 三、运行时数据（Runtime data）
# -----------------------------------------------------------------------------
# 关键目录：后端 SQLite 数据库 + JWT 密钥 + compose 临时数据
# 注意：保留尾部斜杠 (backend/data/) 即可，无需反向规则——整个目录都应排除
# =============================================================================
backend/data/
data/


# =============================================================================
# 四、数据库文件（Database files）
# -----------------------------------------------------------------------------
# 任意位置的 .db / .sqlite / .sqlite3 都排除
#   - *.db 不会匹配 .db-shm / .db-wal（WAL 模式文件），由 backend/data/ 目录级屏蔽
# =============================================================================
*.db
*.sqlite
*.sqlite3


# =============================================================================
# 五、JWT 签名密钥（JWT secrets）
# -----------------------------------------------------------------------------
# 排除 .jwt-secret 文件（含任意位置 + 隐藏文件两种变体）
# 实际由 backend/data/ 目录级兜底，但显式声明更醒目
# =============================================================================
*.jwt-secret
.jwt-secret


# =============================================================================
# 六、环境变量（Environment variables）
# -----------------------------------------------------------------------------
# 项目不依赖 .env（architecture.md §八 禁止），但排除以防误用
# =============================================================================
.env
.env.local
.env.*.local


# =============================================================================
# 七、日志（Logs）
# -----------------------------------------------------------------------------
# 排除所有 .log 文件（含 npm/yarn install log、tsc 输出、Express 服务日志）
# 之前会话已删除 1 个 backend/npm-install.log 残留
# =============================================================================
logs/
*.log
server.log


# =============================================================================
# 八、测试覆盖（Testing）
# -----------------------------------------------------------------------------
# vitest + nyc 覆盖率报告目录
# =============================================================================
coverage/
.nyc_output/


# =============================================================================
# 九、AI 编程工具临时脚本（AI tool ephemeral scripts）
# -----------------------------------------------------------------------------
# 防止 subagent（如 Trae CN）产生 __*.ps1 / __*.sh / __*.js 临时统计脚本
# 2026-07-22 v3.0 引入：之前会话发现 4 个 `__*.ps1` 误留根目录
# 命名前缀 `__` 是 subagent 临时脚本的行业惯例
# =============================================================================
__*.ps1
__*.sh
__*.js


# =============================================================================
# 十、IDE 与编辑器（IDE & Editor）
# =============================================================================
.idea/


# -----------------------------------------------------------------------------
# VSCode：团队级 vscode 配置应入仓，个人配置应排除
# -----------------------------------------------------------------------------
# 关键：必须**显式列出要排除的具体文件**，而不是先排除整个目录再放行
# 反向规则 `!dir/file` 在 Windows git 下对 `dir/*` 模式**不生效**
# 正确策略：白名单（先列要排除的）+ 黑名单（再列要放行的）
#
# 团队级入仓（白名单）：
#   .vscode/settings.json
#   .vscode/extensions.json
#
# 个人/临时不入仓（黑名单）：
#   .vscode/launch.json
#   .vscode/*.code-workspace
#   .vscode/其他任意文件
.vscode/launch.json
.vscode/*.code-workspace
.vscode/*

# 团队共享：编辑设置（缩进、ESLint 集成、推荐插件等）
!.vscode/settings.json

# 团队共享：推荐插件列表（clone 后 VSCode 自动提示安装）
!.vscode/extensions.json

# VSCode 临时文件
*.code-workspace

# -----------------------------------------------------------------------------
# 其他编辑器临时文件
# -----------------------------------------------------------------------------
*.swp
*.swo
*~


# =============================================================================
# 十一、操作系统（OS）
# =============================================================================
.DS_Store
Thumbs.db
desktop.ini


# =============================================================================
# 十二、缓存目录（Cache）
# =============================================================================
.cache/
.temp/
.tmp/


# =============================================================================
# 十三、Docker 运行时数据（Docker runtime data）
# -----------------------------------------------------------------------------
# 与 docker/ 目录（Dockerfile 等）不同：这些是 docker 容器运行时产生的数据
# =============================================================================
backend-data/
backend-logs/
frontend-data/
backend-logs.txt


# =============================================================================
# 十四、TypeScript 增量编译（TypeScript build info）
# =============================================================================
*.tsbuildinfo


# =============================================================================
# 十五、后端开发调试转储（Backend development debug dumps）
# -----------------------------------------------------------------------------
# 实际存在：backend/test-results.json / test-results-p3.json / test-results-p4.json
# 实测 2026-07-22：以上文件确实存在，由 P1-5 / tsc / start / test 流程产生
# =============================================================================
backend/tsc-err.txt
backend/tsc-errors.txt
backend/start-log.txt
backend/test-results.json
backend/test-results-p3.json
backend/test-results-p4.json


# =============================================================================
# 十六、运行时备份（Runtime backups）
# =============================================================================
backend/backups/


# =============================================================================
# 十七、备份文件（Backup files）
# =============================================================================
*.bak

# =============================================================================
# 十八、Lint 输出转储（Lint output dumps）
# =============================================================================
eslint.txt
