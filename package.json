{
  "name": "itops-agent-platform",
  "version": "3.0.5",
  "private": true,
  "description": "企业 IT 运维多 Agent 自动化平台",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "build": "npm run build:backend && npm run build:frontend",
    "build:backend": "cd backend && npm run build",
    "build:frontend": "cd frontend && npm run build",
    "install:all": "npm install && cd backend && npm install && cd ../frontend && npm install",
    "check:arch": "node scripts/check-architecture.js",
    "check:arch:backend": "node scripts/check-architecture.js backend",
    "check:arch:frontend": "node scripts/check-architecture.js frontend",
    "check:deps": "npx depcruise --config .dependency-cruiser.json backend/src",
    "check:deps:graph": "npx depcruise --config .dependency-cruiser.json backend/src --output-type dot | dot -T svg > deps-graph.svg",
    "check:circular": "npx madge --circular --extensions ts backend/src",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md,yml,yaml}\"",
    "prepare": "husky",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:restart": "docker-compose down && docker-compose up -d",
    "docker:rebuild": "docker-compose down && docker-compose up -d --build",
    "docker:status": "docker-compose ps",
    "docker:clean": "docker system prune -f"
  },
  "keywords": [
    "itops",
    "agent",
    "automation",
    "devops"
  ],
  "author": "",
  "license": "MPL-2.0",
  "devDependencies": {
    "concurrently": "^8.2.2",
    "dependency-cruiser": "16.10.4",
    "husky": "^9.1.7",
    "lint-staged": "15.5.2",
    "madge": "^8.0.0",
    "prettier": "3.9.5"
  },
  "lint-staged": {
    "backend/src/**/*.ts": [
      "node scripts/lint-staged.cjs backend"
    ],
    "frontend/src/**/*.{ts,tsx}": [
      "node scripts/lint-staged.cjs frontend"
    ],
    "*.{json,md,yml,yaml}": [
      "npx prettier --write"
    ],
    ".github/**/*.{yml,yaml}": [
      "npx prettier --write"
    ],
    ".trae/**/*.md": [
      "npx prettier --write"
    ],
    "docs/**/*.md": [
      "npx prettier --write"
    ],
    "scripts/**/*.{js,cjs}": [
      "npx prettier --write"
    ]
  }
}
