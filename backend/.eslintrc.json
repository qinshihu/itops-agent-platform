{
  "env": {
    "node": true,
    "es2021": true
  },
  "extends": ["eslint:recommended", "plugin:@typescript-eslint/recommended", "prettier"],
  "parser": "@typescript-eslint/parser",
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module",
    "project": ["./tsconfig.json"]
  },
  "plugins": ["@typescript-eslint"],
  "ignorePatterns": [
    "dist/",
    "node_modules/",
    "*.test.ts",
    "coverage/",
    "scripts/",
    "vitest.config.ts",
    "eslint-local-rules/"
  ],
  "rules": {
    // 2026-07-21 P0-8：no-explicit-any 从 error 降到 warn
    // 原因：126 处 as any 散落在 30+ 文件，全清需 6h+ 工作。短期 open 开源可接受
    // P1 拆大文件时再全局清理（ADR-024）
    "@typescript-eslint/no-explicit-any": "warn",
    // 2026-07-21 P0-8：no-unused-vars 从 error 降到 warn（理由同 no-explicit-any）
    "@typescript-eslint/no-unused-vars": [
      "warn",
      {
        "args": "all",
        "argsIgnorePattern": "^_",
        "caughtErrors": "all",
        "caughtErrorsIgnorePattern": "^_",
        "destructuredArrayIgnorePattern": "^_",
        "varsIgnorePattern": "^_"
      }
    ],
    "@typescript-eslint/explicit-function-return-type": "off",
    "@typescript-eslint/no-inferrable-types": "error",
    "@typescript-eslint/prefer-optional-chain": "warn",
    "@typescript-eslint/consistent-type-imports": ["error", { "prefer": "type-imports" }],
    "no-console": ["error", { "allow": ["warn", "error"] }],
    "prefer-const": "error",
    "no-var": "error",
    "eqeqeq": ["error", "always"],
    "curly": ["error", "multi-line"],
    // 2026-07-21 P1-#17 → 2026-07-21 v2.5：从 warn 升级为 error
    // 详见 docs/开源治理与架构健壮性最终报告_v2.md §8.2 任务 3
    // 升级后：新文件 ≤ 500 行硬约束（CI 真阻断），存量超 500 行文件在下方 overrides 中豁免
    "max-lines": ["error", { "max": 500, "skipComments": true, "skipBlankLines": true }]
  },
  "overrides": [
    {
      // 2026-07-21 P0-8：legacy / 第三方代码 / 服务注册表 / native 桥接层允许 any
      // 完整清理需要后续 P1 大文件拆分（ADR-024）
      "files": [
        "src/serviceRegistry.ts",
        "src/routes/**/*.ts",
        "src/modules/network/**/*.ts",
        "src/modules/scripts/**/*.ts",
        "src/modules/auto/**/*.ts",
        "src/modules/dc/services/dcPduSnmpService.ts",
        "src/modules/dc/services/dcRoomEnvironmentService.ts",
        "src/modules/ai/services/agents/agentExecutionArchiver.ts",
        "src/modules/ai/services/agents/agentToolRegistry.ts",
        "src/modules/ai/services/llm/**/*.ts",
        "src/modules/mcp/services/externalClient/StdioTransport.ts",
        "src/modules/mcp/services/externalClient/SseTransport.ts",
        "src/modules/ai/services/agents/safeCommandBuilder.ts",
        "src/app.ts",
        "src/modules/database/**/*.ts"
      ],
      "rules": {
        "@typescript-eslint/no-explicit-any": "warn",
        "@typescript-eslint/no-unused-vars": [
          "warn",
          {
            "argsIgnorePattern": "^_",
            "varsIgnorePattern": "^_",
            "caughtErrorsIgnorePattern": "^_"
          }
        ],
        "no-useless-escape": "off",
        "eqeqeq": ["warn", "always"]
      }
    },
    {
      // 2026-07-21 P1-#17：测试文件 vi.mock hoists 强制需要 import db
      // 临时豁免（等 P1-#20 补完测试后清理）
      "files": ["src/**/*.test.ts"],
      "rules": {}
    }
  ]
}
