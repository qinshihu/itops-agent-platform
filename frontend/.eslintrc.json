{
  "env": {
    "browser": true,
    "es2021": true
  },
  "extends": ["eslint:recommended", "plugin:@typescript-eslint/recommended", "prettier"],
  "parser": "@typescript-eslint/parser",
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module",
    "project": ["./tsconfig.json", "./tsconfig.node.json", "./tsconfig.vitest.json"]
  },
  "plugins": ["@typescript-eslint"],
  "ignorePatterns": ["dist/", "node_modules/"],
  "overrides": [
    {
      "files": ["*.js", "*.cjs"],
      "parser": "espree",
      "parserOptions": {
        "ecmaVersion": "latest",
        "sourceType": "module"
      },
      "rules": {
        "@typescript-eslint/no-explicit-any": "off",
        "@typescript-eslint/no-unused-vars": "off",
        "@typescript-eslint/prefer-optional-chain": "off",
        "@typescript-eslint/consistent-type-imports": "off",
        "@typescript-eslint/explicit-function-return-type": "off"
      }
    },
    {
      // 2026-07-21 v2.13：存量超 500 行文件 max-lines 豁免清单（实测 10 个）
      // 来源：docs/关于大文件的拆分.md（11 个前端）+ v2.5 二次核实补全（2 个遗漏）= 13 个
      // v2.10 拆除了 Tasks.tsx → Tasks/（13 → 12）
      // v2.12 拆除了 containers/api.ts 850 → 9 桶导出 + containerApi/（12 → 11）
      // v2.13 拆除了 useServerActions.ts 801 → 18 桶导出 + useServerActions/（11 → 10）
      // v2.20 拆除了 BigScreenDashboard.tsx 910 → 121 主入口 + big-screen/ 8 个新 widget（基于已存在的 types.ts / useBigScreenData.ts / BigScreenStatCard.tsx）（10 → 9）
      // v2.21 拆除了 WorkflowProviders.tsx 858 → 64 主入口 + workflow-providers/ 6 个子模块（9 → 8）
      // v2.22 拆除了 AlertProviders.tsx 637 → 163 主入口 + alert-providers/ 6 个子模块（8 → 7）
      // v2.23 拆除了 useWorkflowEditor.ts 646 → 241 主入口 + workflow-editor/ 7 个新 hook 子模块（7 → 6）
      // v2.24 拆除了 ToolLinks.tsx 616 → 105 主入口 + tool-links/ 9 个新 widget 子模块（含 hooks/constants/2 modals/2 widgets/grid）（6 → 5）
      // v2.25 拆除了 SSHKeys.tsx 613 → 115 主入口 + ssh-keys/ 8 个新 widget 子模块（含 hooks/constants/2 modals/2 widgets/card）（5 → 4）
      // v2.26 拆除了 NotificationSettings.tsx 592 → 133 主入口 + notification-settings/ 9 个新 widget 子模块（含 4 channel sections + Toggle 复用 + deep merge helper）（4 → 3）
      // v2.27 清理 Tasks.tsx（由用户/其他 AI 完成的拆分遗留 tsc 错误 5 个）+ 修复 MarkdownOutput 路径深度 2 处 + mutationFn 返回类型 3 处（文件已删除，路径仍指向 Tasks/ 子模块）（3 → 3）
      // v2.28 拆除了 Networks.tsx 599 → 132 主入口 + networks/ 10 个新 widget 子模块（含 2 query + 4 mutation + 7 卡片 widget + IP table + 详情视图）（3 → 2）
      // v2.29 拆除了 DbConnections.tsx 587 → 95 主入口 + db-connections/ 7 个新 widget 子模块（含 1 query + 4 mutation + 4 widget + form modal + delete modal）（2 → 1）
      // v2.30 拆除了 AddDeviceModal.tsx 579 → 102 主入口 + add-device-modal/ 10 个新 widget 子模块（含 2 query + 4 section widget + tab bar + footer + 修正 baseline `data` typo bug）（1 → 0）🎉 frontend overrides 清单清空
      // 拆分计划：见 docs/开源治理与架构健壮性最终报告_v2.md §8 P1 任务 5
      // 豁免策略：仅豁免 max-lines，其他规则不变；拆分后从清单移除
      "files": [],
      "rules": {
        "max-lines": "off"
      }
    }
  ],
  "rules": {
    "@typescript-eslint/no-explicit-any": "error",
    "@typescript-eslint/no-unused-vars": [
      "warn",
      {
        "argsIgnorePattern": "^_",
        "destructuredArrayIgnorePattern": "^_",
        "varsIgnorePattern": "^_"
      }
    ],
    "@typescript-eslint/explicit-function-return-type": "off",
    "@typescript-eslint/prefer-optional-chain": "warn",
    "@typescript-eslint/consistent-type-imports": ["error", { "prefer": "type-imports" }],
    "no-console": ["error", { "allow": ["warn", "error"] }],
    "prefer-const": "error",
    "no-var": "error",
    "eqeqeq": ["error", "always"],
    "curly": ["error", "multi-line"],
    // 2026-07-21 v2.5：从 warn 升级为 error
    // 详见 docs/开源治理与架构健壮性最终报告_v2.md §8.2 任务 3
    // 升级后：新文件 ≤ 500 行硬约束（CI 真阻断），存量超 500 行文件在 overrides 中豁免
    "max-lines": ["error", { "max": 500, "skipComments": true, "skipBlankLines": true }],
    "react/react-in-jsx-scope": "off",
    "react/prop-types": "off"
  }
}
